{
  "name": "oxcom/magento2-top-products",
  "description": "This is a module that extends Magento2 API to get list of TOP products.",
  "type": "magento2-module",
  "license": "LGPL-3.0",
  "keywords": [
    "magento2",
    "top products",
    "api"
  ],
  "homepage": "https://github.com/OxCom/magento2-top-products",
  "require": {
    "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
    "magento/framework": "^103.0",
    "magento/module-backend": "^102.0",
    "magento/module-catalog": "^104.0",
    "magento/module-config": "^101.2",
    "magento/module-directory": "^100.4",
    "magento/module-review": "^100.4",
    "magento/module-sales": "^103.0",
    "magento/module-store": "^101.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
    "slevomat/coding-standard": "^8.15",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "OxCom\\MagentoTopProducts\\": ""
    }
  },
  "autoload-dev": {
    "classmap": []
  },
  "authors": [
    {
      "name": "OxCom",
      "email": "lancer.oxcom@gmail.com"
    }
  ],
  "scripts": {
    "test": "phpunit",
    "phpcs": "phpcs",
    "phpstan": "phpstan analyse --no-progress"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "magento/composer-dependency-version-audit-plugin": true,
      "mage-os/composer-dependency-version-audit-plugin": true
    }
  },
  "repositories": {
    "magento": {
      "type": "composer",
      "url": "https://repo.magento.com/"
    }
  }
}
